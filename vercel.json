{
  "rewrites": [
    {
      "source": "/((?!.*\\.).*)",
      "has": [{ "type": "host", "value": "chat.zionlisboa.pt" }],
      "destination": "/$1.html"
    },
    {
      "source": "/((?!.*\\.).*)",
      "has": [{ "type": "host", "value": "portal.zionlisboa.pt" }],
      "destination": "/admin/$1.html"
    }
  ]
}
